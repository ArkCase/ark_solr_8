#!/bin/bash

set -euo pipefail
. /.functions

ARTIFACT_IDS=(
	com.fasterxml.jackson.dataformat:jackson-dataformat-csv@CROSS_DC_MANAGER_LIB_DIR
	com.fasterxml.jackson.datatype:jackson-datatype-jdk8@CROSS_DC_MANAGER_LIB_DIR
	com.fasterxml.jackson.module:jackson-module-scala_2.13@CROSS_DC_MANAGER_LIB_DIR

	com.fasterxml.jackson.core:jackson-core@WEBAPP_LIB_DIR
	com.fasterxml.jackson.core:jackson-databind@WEBAPP_LIB_DIR
	com.fasterxml.jackson.dataformat:jackson-dataformat-cbor@WEBAPP_LIB_DIR
	com.fasterxml.jackson.dataformat:jackson-dataformat-smile@WEBAPP_LIB_DIR
	com.fasterxml.jackson.module:jackson-module-jakarta-xmlbind-annotations@WEBAPP_LIB_DIR
)

set_or_default BASE_DIR "/app"
set_or_default HOME_DIR "${BASE_DIR}/solr"
set_or_default SERVER_DIR "${HOME_DIR}/server"
set_or_default MODULES_DIR "${HOME_DIR}/modules"
set_or_default CROSS_DC_MANAGER_LIB_DIR "${HOME_DIR}/cross-dc-manager/lib"
set_or_default WEBAPP_DIR "${SERVER_DIR}/solr-webapp/webapp"
set_or_default WEBAPP_LIB_DIR "${WEBAPP_DIR}/WEB-INF/lib"

export CROSS_DC_MANAGER_LIB_DIR WEBAPP_LIB_DIR
export POST_CALL="fix-jar-sum"
exec fix-jars "GHSA-72hv-8253-57qq" "2.21.1" "${ARTIFACT_IDS[@]}"
